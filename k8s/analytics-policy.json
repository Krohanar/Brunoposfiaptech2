{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SqsConsume",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl"
      ],
      "Resource": "arn:aws:sqs:sa-east-1:106978078844:minha-fila"
    },
    {
      "Sid": "DynamoWrite",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:aws:dynamodb:sa-east-1:106978078844:table/ToggleMasterAnalytics"
    }
  ]
}
